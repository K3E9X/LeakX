# LeakX — configuration de l'API.
# Copier en /opt/leakx/api/.env, renseigner les valeurs, puis : chmod 600 .env

# Base de données — PostgreSQL local par défaut (cf. runbook étape 5).
# Base managée Scaleway : remplacer par l'URL de connexion fournie par Scaleway.
LEAKX_DATABASE_URL=postgresql+psycopg://leakx:CHANGE_MOI@localhost:5432/leakx

# Clé d'API abuse.ch (4 flux IOC : ThreatFox, URLhaus, MalwareBazaar, Feodo).
LEAKX_ABUSECH_KEY=

# Rétention RGPD en jours — ne pas augmenter sans décision produit (CLAUDE.md §5).
LEAKX_RETENTION_DAYS=30
